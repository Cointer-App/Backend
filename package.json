{
  "name": "cointer-backend",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run starter.ts",
    "dev": "bun run --watch starter.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.29",
    "nodemailer": "^9.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
